# ==============================================================================
# Jito BAM Sidecar - Configuration Template
# ==============================================================================

# 1. AUTHORITY CONFIGURATION
# ------------------------------------------------------------------------------
# The Base58 encoded private key of the BAM Authority.
# This keypair is responsible for:
#   - Signing aggregated transactions.
#   - Paying for Jito Block Engine tips (MEV).
#   - Submitting ZK-Compression state updates.
BAM_AUTHORITY_KEY=REPLACE_WITH_YOUR_BASE58_PRIVATE_KEY

# 2. NETWORK CONFIGURATION
# ------------------------------------------------------------------------------
# Primary Solana RPC URL (e.g., Helius, QuickNode, or custom validator).
RPC_URL=https://api.mainnet-beta.solana.com

# Jito Block Engine Access Point.
# Use the endpoint closest to your server's region for minimum latency:
#   - US East: https://ny.mainnet.block-engine.jito.wtf/api/v1/bundles
#   - EU Central: https://frankfurt.mainnet.block-engine.jito.wtf/api/v1/bundles
#   - Asia Tokyo: https://tokyo.mainnet.block-engine.jito.wtf/api/v1/bundles
JITO_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles

# 3. ZK-COMPRESSION (LIGHT PROTOCOL)
# ------------------------------------------------------------------------------
# Optional: The Photon Indexer URL. 
# Providing this URL enables the ZK Module for compressed state resolution.
# Example (via Helius): https://mainnet.helius-rpc.com/?api-key=REPLACE_ME
# PHOTON_URL=

# 4. SERVER CONFIGURATION
# ------------------------------------------------------------------------------
# Port for the Axum API server.
PORT=3030

# Enable debug logging (trace, debug, info, warn, error).
RUST_LOG=info

# 5. MAKER QUOTE UPDATER CONFIGURATION
# ------------------------------------------------------------------------------
# The Base58 encoded public key of the market making bot (used to verify incoming signatures)
MAKER_PUBKEY=REPLACE_WITH_BOT_BASE58_PUBKEY

# Comma-separated list of allowed market IDs to prevent DDoS
ALLOWED_MARKETS=SOL/USDC,BTC/USDC

# The interval (in milliseconds) at which the aggregator emits deduplicated Jito bundles
BAM_TICK_RATE_MS=50
